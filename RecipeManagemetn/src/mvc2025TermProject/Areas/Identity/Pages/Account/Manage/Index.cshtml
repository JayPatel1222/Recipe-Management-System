@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}
<div class=" bg-light border rounded-3 p-5">
<h3>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />
<div class="row">
    <div class="col-md-6">
        <form id="profile-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Username" class="form-control" placeholder="Please choose your username." disabled />
                <label asp-for="Username" class="form-label p-2"></label>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="FullName" class="form-control" placeholder="Please choose your username." disabled />
                    <label asp-for="FullName" class="form-label p-2">Full Name</label>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Municipality" class="form-control" placeholder="Please choose your username." disabled />
                    <label asp-for="Municipality" class="form-label p-2"></label>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="StreetAddress" class="form-control" placeholder="Please choose your username." disabled />
                    <label asp-for="StreetAddress" class="form-label p-2">Street Address</label>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Please enter your phone number."/>
                    <label asp-for="Input.PhoneNumber" class="form-label p-2">Phone Number</label>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>
            <button id="update-profile-button" type="submit" class="w-100 btn btn-lg btn-primary">Save</button>
        </form>
    </div>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
