@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}
<div class="container mt-4">
    <h1>@ViewData["Title"]</h1>

    <div class="row justify-content-center bg-light border rounded-3 p-5">
        <div class="col-lg-8">
            <form asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <h2>Create a new account</h2>
                <hr />
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="row">

                    <div class="col-md-6">

                        <div class="row mb-3 mt-2">
                            <div class="col-md-6">
                                <label asp-for="Input.FirstName"></label>
                                <input asp-for="Input.FirstName" class="form-control" />
                                <span asp-validation-for="Input.FirstName" class="text-danger fs-6"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.MiddleName"></label>
                                <input asp-for="Input.MiddleName" class="form-control" />
                                <span asp-validation-for="Input.MiddleName" class="text-danger fs-6"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.LastName"></label>
                            <input asp-for="Input.LastName" class="form-control" />
                            <span asp-validation-for="Input.LastName" class="text-danger fs-6"></span>
                        </div>

                        <div class="row mb-3 mt-2">
                            <div class="col-md-6">
                                <label asp-for="Input.StreetAddress"></label>
                                <input asp-for="Input.StreetAddress" class="form-control" />
                                <span asp-validation-for="Input.StreetAddress" class="text-danger fs-6"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.Municipality"></label>
                                <input asp-for="Input.Municipality" class="form-control" />
                                <span asp-validation-for="Input.Municipality" class="text-danger fs-6"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.DOB"></label>
                            <input asp-for="Input.DOB" class="form-control" />
                            <span asp-validation-for="Input.DOB" class="text-danger fs-6"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Input.PhoneNumber"></label>
                            <input asp-for="Input.PhoneNumber" class="form-control" />
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger fs-6"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.Email"></label>
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger fs-6"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.Password">Password</label>
                            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                            <span asp-validation-for="Input.Password" class="text-danger fs-6"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger fs-sm-3"></span>
                        </div>
                    </div>
                </div>

                <div class="mb-3 mt-3">
                    <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">Register</button>
                    <a asp-page="./Login" class="btn btn-outline-secondary btn-lg w-100 w-md-50 mt-2">
                        Login
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
